# 1. 내 프로필 정보 가져오기 (GET API)
# 이 API는 Supabase에 저장된 내 프로필 데이터를 단건으로 조회합니다.
GET http://localhost:3000/api/profiles


### 2. 프로필 생성 및 수정하기 (POST API 테스트)
# 프론트엔드 화면 없이 백엔드만 직접 찔러서 DB에 데이터를 넣습니다.
POST http://localhost:3000/api/profiles
Content-Type: application/json

{
  "username": "지니 (API 테스트)",
  "email": "test@api.com",
  "bio": "REST Client로 쏘아올린 테스트 데이터입니다.",
  "role": "designer",
  "marketing_emails": true,
  "theme": "system",
  "avatar_url": ""
}